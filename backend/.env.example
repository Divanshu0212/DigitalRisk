# Asyncpg-compatible PostgreSQL DSN. Required.
DATABASE_URL=postgresql://postgres:password@localhost:5432/txndb

# Comma-separated list of allowed CORS origins (default: * in dev).
ALLOWED_ORIGINS=*

# Transactions allowed per user per 60s window.
RATE_LIMIT_PER_MINUTE=20

# Minimum net balance permitted (debits below this are rejected).
BALANCE_FLOOR=-50000

# Maximum single-transaction amount.
MAX_TRANSACTION_AMOUNT=1000000

# Optional: how long (seconds) to cache the /ranking result in-process.
RANKING_CACHE_TTL=15
